# Copiez ce fichier en .env et remplissez vos valeurs

# Votre clé API Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Mot de passe pour accéder à l'application
APP_PASSWORD=votre-mot-de-passe

# Clé secrète pour chiffrer les sessions (mettez une longue chaîne aléatoire)
SESSION_SECRET=changez-cette-valeur-par-une-chaine-aleatoire-longue

# Chemin de stockage des données (IMPORTANT pour la persistance sur Hostinger)
# En local : laisser vide (utilise data/ dans le projet)
# Sur Hostinger : /home/u800131214/histoire-data  (remplacez u800131214 par votre identifiant)
# DATA_PATH=

# Port du serveur (Hostinger le définit automatiquement)
PORT=3000

# Environnement : development ou production
NODE_ENV=production
